# ============================================
# JARVIS - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com suas chaves
# NUNCA commite o arquivo .env para o GitHub!
# ============================================

# Google Gemini API (Obrigatório)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=sua_chave_google_aqui

# Mem0 - Sistema de Memória (Obrigatório)
# Obtenha em: https://app.mem0.ai
MEM0_API_KEY=sua_chave_mem0_aqui

# LiveKit - Comunicação em Tempo Real (Obrigatório)
# Obtenha em: https://livekit.io
LIVEKIT_URL=wss://sua_url_livekit
LIVEKIT_API_KEY=sua_api_key_livekit
LIVEKIT_API_SECRET=seu_api_secret_livekit

# ============================================
# PLUGINS - APIs Opcionais
# ============================================

# OpenWeatherMap - Plugin de Clima (Opcional)
# Obtenha em: https://openweathermap.org/api (grátis)
OPENWEATHER_API_KEY=

# GitHub - CodeAssistant Plugin (Opcional)
# Obtenha em: https://github.com/settings/personal-access-tokens/new
# Escopos necessários: repo, read:org (para análise de código)
GITHUB_TOKEN=

# Trello - Integração com Trello (Opcional)
TRELLO_API_KEY=
TRELLO_TOKEN=

# Notion - Integração com Notion (Opcional)
NOTION_API_KEY=
NOTION_DATABASE_ID=
